{
  "gateway": {
    "bind": "loopback",
    "port": 19001,
    "controlUi": {
      "enabled": true,
      "basePath": "/controlui",
      "allowedOrigins": [
        "https://soc.company.example",
        "https://admin-soc.company.example"
      ]
    },
    "auth": {
      "mode": "password",
      "password": "CHANGE_ME_ADMIN_PASSWORD",
      "rateLimit": {
        "maxAttempts": 10,
        "windowMs": 60000,
        "lockoutMs": 300000,
        "exemptLoopback": true
      }
    },
    "http": {
      "endpoints": {
        "responses": {
          "enabled": true
        }
      }
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "openai-codex/gpt-5.4"
      },
      "compaction": {
        "mode": "safeguard",
        "reserveTokens": 12000,
        "reserveTokensFloor": 12000,
        "keepRecentTokens": 8000,
        "maxHistoryShare": 0.7,
        "recentTurnsPreserve": 3,
        "identifierPolicy": "strict"
      },
      "workspace": "~/.openclaw/workspace-main",
      "thinkingDefault": "medium",
      "heartbeat": {
        "every": "0m"
      }
    },
    "list": [
      {
        "id": "eon",
        "default": true,
        "workspace": "~/.openclaw/workspace-eon",
        "identity": {
          "name": "Eon"
        }
        ,
        "heartbeat": {
          "every": "1h",
          "isolatedSession": true
        }
      },
      {
        "id": "minji",
        "workspace": "~/.openclaw/workspace-minji",
        "identity": {
          "name": "민지"
        }
      },
      {
        "id": "jiwon",
        "workspace": "~/.openclaw/workspace-jiwon",
        "identity": {
          "name": "지원"
        }
      }
    ]
  },
  "cron": {
    "enabled": false
  },
  "plugins": {
    "entries": {
      "openai": {
        "enabled": true
      }
    }
  },
  "skills": {
    "load": {
      "extraDirs": [
        "/opt/platformclaw/skills"
      ]
    }
  },
  "meta": {
    "lastTouchedVersion": "2026.4.6",
    "lastTouchedAt": "2026-04-07T19:41:57.929Z"
  }
}
